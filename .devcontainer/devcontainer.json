{
  "name": "Epidauros Dev Environment",
  "dockerComposeFile": "../compose.yaml",
  "service": "app",
  "workspaceFolder": "/app",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "charliermarsh.ruff",
        "astral-sh.astral-uv",
        "ms-azuretools.vscode-docker",
        "tamasfe.even-better-toml"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/app/.venv/bin/python",
        "python.analysis.extraPaths": ["${workspaceFolder}"],
        "python.analysis.unittestEnabled": false,
        "python.testing.pytestEnabled": true
      }
    }
  },
  "remoteUser": "root",
  "forwardPorts": [8501, 5432, 6333]
}
